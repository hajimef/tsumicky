<xml id="toolbox_display_unor4wifi" style="display: none">
  <category id="category_display_unor4wifi" name="UNO R4 WiFi" colour="255">
    <block type="unor4wifi_matrix_init"></block>
    <block type="unor4wifi_matrix_show_frame"></block>
    <block type="unor4wifi_matrix_show_bitmap"></block>
    <block type="unor4wifi_matrix_show_animation"></block>
    <block type="unor4wifi_matrix_scroll_text">
      <value name="TEXT">
        <shadow type="text">
          <field name="TEXT">Hello</field>
        </shadow>
      </value>
      <value name="SPEED">
        <shadow type="math_number">
          <field name="NUM">100</field>
        </shadow>
      </value>
    </block>
    <block type="unor4wifi_matrix_clear"></block>
  </category>
</xml>
