<xml id="toolbox_display_rpi500p" style="display: none">
  <category id="category_display_rpi500p" name="Raspberry Pi 500+" colour="165">
    <block type="rpi500p_kbled_init"></block>
    <block type="rpi500p_kbled_set">
      <value name="row">
        <shadow type="math_number">
          <field name="NUM">1</field>
        </shadow>
      </value>
      <value name="col">
        <shadow type="math_number">
          <field name="NUM">1</field>
        </shadow>
      </value>
      <value name="color">
        <block type="colour_picker">
          <field name="COLOUR">#ff0000</field>
        </block>
      </value>
    </block>
    <block type="rpi500p_kbled_show"></block>
    <block type="rpi500p_kbled_buf_clear"></block>
    <block type="rpi500p_kbled_clear"></block>
  </category>
</xml>
